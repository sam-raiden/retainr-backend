# ============================================================================
# Kai Green Fitness backend — environment variables
# Copy to `.env` and fill in real values. Server refuses to boot if anything
# required is missing or malformed (see src/config/env.ts).
# ============================================================================

# ----- Node ------------------------------------------------------------------
NODE_ENV=development                          # development | production | test
PORT=8080                                     # HTTP port Fastify listens on
LOG_LEVEL=info                                # trace | debug | info | warn | error | fatal


# ----- Database (Supabase Postgres) ------------------------------------------
# Connect as `postgres.<project-ref>` through the TRANSACTION POOLER
# (port 6543) — Supavisor (Supabase's pooler) only resolves usernames of the
# form `postgres.<project-ref>`; custom roles like `app_backend` fail at the
# pooler with "(ENOTFOUND) tenant/user ... not found" before Postgres auth
# even runs.
#
# This does NOT mean RLS is bypassed. Every query path in src/db/pool.ts
# runs `SET LOCAL ROLE app_backend` (NOBYPASSRLS) at the start of its
# transaction — `SET LOCAL` resets at COMMIT/ROLLBACK, so it's safe under
# transaction-mode pooling. verifyTenancySetup() checks this at boot and
# refuses to start if app_backend can't be reached or has BYPASSRLS.
#
# One-time prerequisite (already applied to this project):
#   GRANT app_backend TO postgres;
#
# Format (get the exact host from Supabase Dashboard > Project Settings >
# Database > Connection string > Transaction):
#   postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres

# Optional admin connection (BYPASSRLS) used ONLY by migrations or one-off
# rescue work. Leave blank in normal operation.
DATABASE_ADMIN_URL=


# ----- Supabase project (for Storage SDK only) -------------------------------
# Storage SDK uses the service-role key to upload member photos. We scope
# tenancy ourselves via the object key prefix (<gym_id>/<member_id>/…).
# The Storage SDK does NOT touch RLS-protected operational tables.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-supabase-dashboard>
SUPABASE_STORAGE_BUCKET=member-photos


# ----- Auth ------------------------------------------------------------------
# Long random secret used to sign JWTs the backend issues at /auth/login.
# Generate one with:    openssl rand -hex 48
JWT_SECRET=<generate-with-openssl-rand-hex-48>
JWT_EXPIRES_IN=12h                            # @fastify/jwt format: 12h, 7d, etc.


# ----- CORS ------------------------------------------------------------------
# Comma-separated allow-list of frontend origins.
# Localhost dev origins are auto-allowed when NODE_ENV=development.
CORS_ORIGINS=https://kai-green-fitness.netlify.app,https://kai-green-fitness.vercel.app


# ----- Redis (BullMQ — only required in step 8 onwards) ----------------------
# Leave blank for steps 2–7. The server boots without it.
REDIS_URL=


# ----- WhatsApp BSP (step 9 — leave blank until then) ------------------------
BSP_API_URL=
BSP_API_KEY=
BSP_TEMPLATE_ID=
